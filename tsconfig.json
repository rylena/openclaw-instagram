{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": ".",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ESNext",
		"allowImportingTsExtensions": false,
		"noEmit": false,
		"incremental": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true
	},
	"include": [
		"**/*.ts",
		"**/*.tsx"
	],
	"exclude": [
		"node_modules"
	]
}
